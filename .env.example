# ShipSquares control-plane configuration (twelve-factor; env only).
# Copy to .env for local dev. Every key here is validated by packages/shared/src/env.ts.
# Production values are injected by the installer via the systemd EnvironmentFile (18-installer-ops.md).

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres (control plane — native; 03-data-model.md). Credentials match
# infra/docker-compose.dev.yml for the Option-A dev flow.
DATABASE_URL=postgres://postgres:dev@localhost:5432/shipsquares_dev

# Deploy executor (06-deploy-engine.md). Optional; sensible defaults.
# SS_BUILDS_DIR=/var/lib/shipsquares/builds
# SS_APP_PORT=8080
# SS_HEALTH_ATTEMPTS=30

# better-auth (05-auth-rbac.md) — AUTH_SECRET must be >= 32 chars
AUTH_SECRET=dev-secret-change-me-0123456789abcdef
AUTH_URL=http://localhost:3000

# Caddy admin API (08-proxy-ssl.md)
CADDY_ADMIN_URL=http://localhost:2019

# Proxy driver: caddy | traefik | nginx
PROXY_DRIVER=caddy

# Default inbound webhook signing key (per-repo secrets override; 10-webhooks-vcs.md). Optional.
WEBHOOK_SIGNING_KEY=

# Secret store master key (11-secrets-config.md): base64 of 32 random bytes.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required for env secrets, webhooks, and VCS connections.
SHIPSQUARES_MASTER_KEY=

# GitHub App (26-vcs-connections.md) — the connect-GitHub flow. All optional.
# Slug from the App's URL; numeric App ID; the PEM private key (use the quoted
# multiline form in .env files, or base64 it for systemd EnvironmentFile).
GITHUB_APP_SLUG=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Platform SMTP for email notification channels (30-notifications.md). Optional.
# e.g. SMTP_URL=smtp://user:pass@smtp.example.com:587  SMTP_FROM=ship@example.com
SMTP_URL=
SMTP_FROM=

# Platform Claude key for the AI chat (22-chatbot-agent.md). Optional — org
# admins can set a BYO key via /ai-settings, which takes precedence.
ANTHROPIC_API_KEY=

# Extra browser origins (comma-separated) trusted for login/CORS beyond
# AUTH_URL. Rarely needed: the dashboard itself works at ANY host that
# reaches the server (IP, domain, SSH tunnel) — same-origin is auto-trusted.
# Set this only for genuinely cross-origin callers (e.g. a separately hosted
# frontend): AUTH_TRUSTED_ORIGINS=https://other-frontend.example.com
AUTH_TRUSTED_ORIGINS=

# SSO / social login (ROADMAP R3.2). Optional — a provider's button appears
# only when both its id and secret are set. These are OAuth apps for LOGIN
# (redirect/callback URL: <AUTH_URL>/auth/callback/github|google), separate
# from the VCS GitHub App above.
SSO_GITHUB_CLIENT_ID=
SSO_GITHUB_CLIENT_SECRET=
SSO_GOOGLE_CLIENT_ID=
SSO_GOOGLE_CLIENT_SECRET=

# Public email/password self-signup. Leave "true" for first-run bootstrap;
# set "false" once you onboard via invites (ROADMAP R3.4) so strangers can't
# self-register on your control plane.
ALLOW_SIGNUP=true

# OAuth client credentials for token refresh (26-vcs-connections.md). Optional —
# only needed for oauth-kind connections with expiring tokens.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
